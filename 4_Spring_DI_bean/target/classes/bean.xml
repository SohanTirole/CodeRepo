<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans" 
		xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
		xmlns:context="http://www.springframework.org/schema/context" 
		xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
		

	
	 
	
	<context:annotation-config/>
	
	<bean id="smservice" class="com.spring.SMSService"></bean>

	<bean id="helloService" class="com.spring.HelloService">
		<property name="helloMessage" value="Hello service message is printed"></property>
	</bean>
	
	
	<bean id="emailService" class="com.spring.EmailService">
		<constructor-arg value="this is email service bean message"/>
	</bean>
	
	<bean id="userService" class="com.spring.UserService">
		<constructor-arg ref="emailService"/>
		<property name="helloService" ref="helloService"></property> 
	</bean>

</beans>